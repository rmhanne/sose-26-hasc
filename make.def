# define here the compilers and options to be used in all makefiles in the subdirectories
# I want to keep it as simple as possible and not fiddle around with build system issues

######################
# define your architecture, currently supports: generic, arm, intel
######################

ARCHITECTURE = arm

######################
# define availability of programming models by commenting in/out the following lines
######################

HAVE_MPI = 1

HAVE_OPENMP = 1

HAVE_TBB = 1

#HAVE_SYCL = 1

######################
# set all the different compilers
######################

# C++ compiler for sequential programs
CC = g++

# C++ compiler for openMP programs
CCOMP = $(CC)

# C++ compiler for MPI programs
CCMPI = mpicxx 

# C++ compiler to be used for Intel oneAPI TBB programs
CCTBB = $(CC)

# C++ compiler to be used for Intel oneAPI Sycl programs
DPCPP = icpx -fsycl

######################
# set compilation options for various configurations
######################

# options to be used with all compilers
CCFLAGSBASE =  -O3 -fno-trapping-math -funroll-loops -ffast-math -fargument-noalias

# additional flags for openMP compilation
OMPFLAGS = -fopenmp

# additional flags for MPI compilation
MPIFLAGS = 

# additional flags to enforce no autovectorization
SCALARFLAGS = -fno-tree-vectorize

# additional flags for ARM neon compilation
ARMFLAGS = -ftree-vectorize -march=armv8-a+dotprod -fopt-info-vec

# additional flags for sse2 compilation
SSE2FLAGS = -ftree-vectorize -msse2 -fopt-info-vec

# additional flags for AVX2 compilation
AVX2FLAGS = -ftree-vectorize -mavx2 -mfma -fopt-info-vec

# additional flags for AVX512 compilation
AVX512FLAGS = -ftree-vectorize -mavx512f -mfma -fopt-info-vec

# flags for vectorization; need to adapt this to your hardware
# these flags are for programs relying only on vectorization with compiler options
ifeq ($(ARCHITECTURE),arm)
VECTORIZATIONFLAGS = $(ARMFLAGS)
endif
ifeq ($(ARCHITECTURE),intel)
VECTORIZATIONFLAGS = $(AVX512FLAGS)
endif

# flags for vectorization with std::simd; need to adapt this to your hardware
ifeq ($(ARCHITECTURE),arm)
STDSIMDFLAGS = -std=c++26 $(ARMFLAGS)
endif
ifeq ($(ARCHITECTURE),intel)
STDSIMDFLAGS = -std=c++26 $(AVX512FLAGS)
endif

# flags for TBB targets
TBBFLAGS = -I/opt/local/libexec/onetbb/include
#TBBFLAGS = -I/opt/intel/oneapi/2025.3/include

# additional flags for Intel oneAPI Sycl compilation 
DPCPPFLAGS = -I/opt/intel/oneapi/2025.3/include


######################
# now set linker options for various configurations
######################

# linker options used in all configurations
LFLAGS = -lm

# additional options for openMP programs
LFLAGSOMP = -lpthread

# additional options for mpi programs
LFLAGSMPI = -lpthread

# additional options for TBB programs
LFLAGSTBB = -L/opt/local/libexec/onetbb/lib/ -ltbb
#LFLAGSTBB = -L/opt/intel/oneapi/2025.3/lib/ -ltbb

# additional options for oneAPI Sycl programs
LFLAGSDPCPP =
